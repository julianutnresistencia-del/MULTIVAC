//Normal (podria aceptar o no )

// === ESCENARIO GENERAL DE AUTOMATIZACION ===

// Control de iluminación por luz y movimiento
WHEN sensor_luz < 200lux AND sensor_movimiento == TRUE DO
    foco_sala.estado = ON
    foco_sala.brillo = 75%
    foco_sala.color = warm_white
END

// Climatización inteligente con condiciones anidadas
WHEN sensor_temp_ext > 30°C DO
    IF sensor_temp_int > 27°C THEN
        aire_acondicionado.estado = ON
        aire_acondicionado.modo = FRIO
        aire_acondicionado.temp_objetivo = 23°C
    ELSE
        ventilador_techo.estado = ON
        ventilador_techo.velocidad = 3
    END
END

// Automatización nocturna cada cierto tiempo
EVERY 15m DO
    IF reloj.hora > 21:30 AND alarma.estado == OFF THEN
        persiana_sala.posicion = 0%
        luces_exteriores.estado = ON
        altavoz_sala.volumen = 20%
        altavoz_sala.mensaje = "Modo noche activado"
    END
END

// Seguridad ante humo
IF sensor_humo == TRUE THEN
    alarma.estado = ON
    cerradura_principal.estado = OFF
    persiana_sala.posicion = 100%
    altavoz_sala.mensaje = "PELIGRO: HUMO DETECTADO"
    altavoz_sala.email = emergencia@smart-home.com
END



// --- Palabras reservadas en mayuscula/minuscula/mezcladas ---
IF foco.estado == ON THEN
    aire.temp_obj = 25°c
END

When sensor_movimiento == True Do
    alarma.activada = On
end

EVERY 10h DO
    persiana.posicion = 50%
END

// --- Bloque if/then/else completo ---
if aire.estado == on then
    persiana.posicion = 0%
else
    persiana.posicion = 100%
end

// --- Combinacion de condiciones and / or / not ---
if sensor_movimiento == true and sensor_humo == false then
    alarma.activada = on
end

if sensor_temp > 25°c or sensor_humedad < 40% then
    aire.estado = on
end

if not sensor_movimiento == true then
    foco.estado = off
end

