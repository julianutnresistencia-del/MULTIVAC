persiana.brillo

// Porcentaje con signo negativo (no deberia existir para %)
-10%

// Porcentaje justo un numero por encima del limite
101%

// Temperatura justo un grado por encima del limite superior
51°c

// Temperatura justo un grado por debajo del limite inferior
-31°c

// Tiempo negativo
-5h

// Tiempo con sufijo invalido (no es h, m ni s)
10d

// Luz justo un numero por encima del limite
1001lux

// Luz negativa
-100lux

// Fecha con dia 00 (no existe el dia cero)
00/06/2024

// Fecha con mes 00
15/00/2024

// Fecha con anio menor al rango permitido
15/06/1899

// Fecha con anio mayor al rango permitido
15/06/2100

// Fecha 31 de un mes de 30 dias
31/04/2024

// Hora con formato de un solo digito en la hora
9:30

// Hora con minutos de un solo digito
09:5

// Hora con la hora en negativo (no tiene sentido, deberia fallar)
-1:00

// Email sin usuario antes de la arroba
@dominio.com

// Email con doble arroba
usuario@@dominio.com

// Email con extension de un solo caracter invalido tras el punto (numero)
