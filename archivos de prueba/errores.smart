// === BLOQUE CON ERRORES LEXICOS INTENCIONALES ===

// Error 1: símbolo inválido '@@'
WHEN sensor_luz @@ 300lux DO
    foco_error.estado = ON
END

// Error 2: número mal formado
foco_sala.brillo = 80%%

// Error 3: string sin cerrar
altavoz_sala.mensaje = "Mensaje sin cerrar

// Error 4: identificador inválido
1sensor.estado = ON

// Error 5: operador incorrecto
IF sensor_temp_int => 25°C THEN
    aire_acondicionado.estado = ON
END

// Error 6: email mal formado
altavoz_sala.email = usuario@@dominio.com